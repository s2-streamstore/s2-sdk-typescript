{
  "name": "@s2-dev/resumable-stream",
  "version": "2.0.0",
  "description": "Resumable streams based on s2.dev, inspired by Vercel's implementation.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://s2.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/s2-streamstore/s2-sdk-typescript"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aisdk": {
      "types": "./dist/aisdk.d.ts",
      "default": "./dist/aisdk.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome check",
    "test": "vitest --run"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@s2-dev/streamstore": ">=0.21.0",
    "ai": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^6.0.142"
  }
}
